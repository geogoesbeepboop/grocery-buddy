{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/secret_scan.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/system_reference_reminder.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pytest_on_stop.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(make format)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pytest:*)"
    ]
  }
}
