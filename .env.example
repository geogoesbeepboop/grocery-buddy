# ── Langfuse (optional — traces are no-ops when keys are absent) ───────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Telegram — the sole notification and chat channel ─────────────────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot
# 2. Copy the token it gives you below.
# 3. DM your new bot once (any message), then read your chat ID:
#      curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    Look for result[0].message.chat.id
# 4. Register the webhook (run once, after the server is publicly reachable):
#      curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<WEBHOOK_BASE_URL>/telegram"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Your user UUID (from `make seed`) — inbound Telegram messages are attributed to this user
GROCERY_BUDDY_USER_ID=

# Public URL where the webhook server is reachable from the internet.
# For local dev use ngrok: ngrok http 8080  → copy the https URL here
WEBHOOK_BASE_URL=https://<your-domain-or-ngrok>.ngrok-free.app

# ── Purchase settings ─────────────────────────────────────────────────────────
# Reserved for a future auto-buy tier — NOT enforced today. Every cart is sent to
# you for approval over Telegram regardless of total; on approval the agent stages
# the Amazon cart and hands back a checkout link (it never places the order itself).
AUTO_PURCHASE_CAP_USD=50.0

# After staging a checkout, how long the workflow keeps a durable ear open for your
# "I placed the order" confirmation before giving up. On confirm, the items are
# tracked as in-transit and the pantry tops up when they arrive. If you never
# confirm, we simply never assume the order happened. 72h covers a weekend.
PURCHASE_CONFIRM_WAIT_HOURS=72

# ── Evals, cost & the money-live readiness gate ───────────────────────────────
# Per-run LLM cost (USD) above which the cost alert fires. The run's cost is summed
# from the llm_usage ledger (real, was a hardcoded 0.0 before). See docs/EVALS.md.
COST_ALERT_THRESHOLD_USD=1.00
# Prediction-accuracy eval window: score snapshots from the last LOOKBACK_DAYS against
# purchases within HORIZON_DAYS of each snapshot.
EVAL_LOOKBACK_DAYS=14
EVAL_HORIZON_DAYS=7
# Money-live readiness gate (gating.py). The auto-buy spine is built sandbox-first but
# money-live-READY — flipping MONEY_LIVE on is only honored when EVERY gate condition
# passes. These default OFF; money stays off until you explicitly enable both flags AND
# the predictor/cost/scraper conditions pass (and checkout_verified, a hard stop today).
AUTO_BUY_ENABLED=false
MONEY_LIVE=false
GATE_PREDICTOR_PRECISION_FLOOR=0.70
GATE_RUN_COST_CEILING_USD=0.50
# Rolling cap on the persisted per-user chat transcript (~20 turns) so onboarding/import
# transcripts can't grow unbounded and get re-sent in full every webhook turn.
CONVERSATION_MAX_MESSAGES=40

# ── Grocery run behavior ──────────────────────────────────────────────────────
# Free next-day shipping floor. Amazon's Prime grocery / add-on free-shipping minimum
# is ~$25; below it you may pay a delivery fee. When a run's cart lands under this, the
# agent tops it up with the items due to run out soonest (clearly labeled, droppable at
# approval) so the whole order ships free.
FREE_SHIPPING_THRESHOLD_USD=25.0
# Cap on the "added to reach free shipping" fillers — both how many we price (each is a
# browser search) and how many we'll actually add. Keeps a small run from ballooning.
FREE_SHIPPING_MAX_FILLERS=6
# Most items to list per stock bucket in /status (and the post-import recap) before
# collapsing the rest into a "…and N more" line — a 90-item pantry listed in full
# overflows Telegram's 4096-char message limit. 0 = no cap.
STATUS_MAX_ITEMS_PER_BUCKET=12
# Scheduled-run guardrail: skip a new full grocery run if one already ran for the user
# within this many minutes (prevents stacked briefings on a high-frequency cron like
# */5). Ad-hoc QuickBuys are never blocked by this.
RUN_COOLDOWN_MINUTES=180

# ── Amazon automation ─────────────────────────────────────────────────────────
# Directory to store the persistent Playwright browser profile (Amazon session)
AMAZON_PROFILE_DIR=.amazon-session
# Set to "true" for production (headless), "false" for interactive setup
AMAZON_HEADLESS=true
# First name of the primary shopper. /import types this into the Amazon orders
# search box so it only pulls THIS person's orders (an account can host several
# household profiles). Leave blank to import the full, unfiltered order history.
AMAZON_ACCOUNT_FIRST_NAME=
# Self-healing re-login. When the saved session expires, the system signs back in
# on its own — no `make amazon-setup` needed. Set these to log in fully unattended
# (works on scheduled runs); leave them blank to have it open a login window for
# you instead. If Amazon asks for a 2FA code, it's relayed to you over Telegram.
AMAZON_EMAIL=
AMAZON_PASSWORD=
# Household profile to pick after sign-in ("Who's shopping?"), if shown. Defaults
# to AMAZON_ACCOUNT_FIRST_NAME when blank.
AMAZON_PROFILE_NAME=
# Seconds to wait for your 2FA code / interactive login before giving up.
AMAZON_LOGIN_WAIT_SECONDS=240
# How deep /import reads the order history, and the page cap. Larger = more
# history but more pages (each paced a few seconds apart to stay polite).
AMAZON_IMPORT_MAX_PAGES=20
AMAZON_IMPORT_MAX_ORDERS=200
# Output-token budget for the Sonnet synthesis that turns scraped orders into a
# pantry proposal. Leave at 0 to auto-scale to the number of products (~240 tokens
# each, capped near Sonnet's 64k max) so a 200-item history never truncates. Set a
# positive number only to pin an explicit ceiling.
AMAZON_IMPORT_SYNTHESIS_MAX_TOKENS=0

# ── Browser-automation resilience ─────────────────────────────────────────────
# Amazon pins us to its internal CSS ids; a redesign breaks them silently. This layer
# (automation/resilience.py + network.py) makes selectors self-healing and observable.
# Abort image/media/font + ad/telemetry requests on the READ paths (search, order
# scrape) — speeds loads and fixes "Amazon pages never go idle". Never applied to
# sign-in or add-to-cart. Disable only if a future change relies on blocked content.
AMAZON_BLOCK_HEAVY_RESOURCES=true
# Where the self-heal layer persists selectors it rediscovered. Kept OUTSIDE the browser
# profile (which the scraper copies/wipes) so a healed selector survives.
SELECTOR_CACHE_PATH=.selector-cache.json
# On a deterministic 0-match, ask an LLM over the accessibility tree to relocate the
# element, then cache the answer. Only ever runs on a 0-match, so the hot path stays
# deterministic. Set false to fail fast instead of self-healing.
SELECTOR_REPAIR_ENABLED=true
# Attach a screenshot to the repair prompt (vision) as a last resort — costs more per
# repair; the accessibility tree alone is usually enough. Off by default.
SELECTOR_REPAIR_VISION=false
# Model for selector repair. Blank → MODEL_SMART (Sonnet); repair reasons over a whole
# accessibility tree, so it benefits from a stronger model.
SELECTOR_REPAIR_MODEL=
# Page you (Telegram) when a make-or-break selector matches 0 across a whole run —
# turning the old silent "couldn't pull from Amazon" into an actionable alert.
SELECTOR_HEALTH_ALERTS=true
